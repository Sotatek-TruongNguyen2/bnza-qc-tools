# Preferred paid RPC (always rotated with public backups)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_key

# Optional: extra RPCs for rotation (comma or whitespace separated)
# BASE_RPC_URLS=https://base.llamarpc.com,https://1rpc.io/base

# Or Alchemy key only (app builds Base URL and still rotates public backups)
# ALCHEMY_API_KEY=

# Optional: Etherscan API V2 key — speeds up “opened at” price (full mint history)
# ETHERSCAN_API_KEY=

# Optional: if checked out next to bonanzapool, next.config also loads
# ../bonanzapool/contracts/bnza-exbot/.env
