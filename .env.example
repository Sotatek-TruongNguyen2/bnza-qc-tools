# Preferred for Vercel / local
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_key

# Or Alchemy key only (app builds Base URL)
# ALCHEMY_API_KEY=

# Optional: Etherscan API V2 key — speeds up “opened at” price (full mint history)
# ETHERSCAN_API_KEY=

# Optional: if checked out next to bonanzapool, next.config also loads
# ../bonanzapool/contracts/bnza-exbot/.env
